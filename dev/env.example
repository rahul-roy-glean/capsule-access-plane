# Environment variables for local development.
# Copy to .env and adjust as needed:  cp .env.example .env

# Required: shared HMAC secret for runner attestation tokens.
ATTESTATION_SECRET=local-dev-secret

# Credential injected into outbound API calls (Bearer token).
# For local testing, any dummy value works unless you're hitting real APIs.
GITHUB_TOKEN=ghp_fake_local_dev_token

# Optional overrides (defaults shown):
# LISTEN_ADDR=:8080
# DATABASE_URL=capsule-access.db
# CREDENTIAL_REF=env:GITHUB_TOKEN
